# 2GIS to Traccar Bridge Environment Configuration
# Copy this file to .env and update the values

# REQUIRED: 2GIS WebSocket base URL (no token - injected from refresh)
TWOGIS_WS_URL=wss://zond.api.2gis.ru/api/1.1/user/ws?appVersion=6.31.0&channels=markers,sharing,routes

# REQUIRED: 2GIS refresh token (dg5_auth_refresh_token from browser DevTools → Application → Cookies → 2gis.kz)
TWOGIS_REFRESH_TOKEN=your_dg5_auth_refresh_token_value

# Optional: 2GIS Auth
# TWOGIS_AUTH_REFRESH_URL=https://2gis.kz/_/auth/refresh
# TWOGIS_TOKEN_FILE=.2gis_tokens.json

# REQUIRED: Traccar Server Configuration
# Your Traccar server URL with OsmAnd port (usually 5055)
TRACCAR_BASE_URL=http://your-traccar-server:5055

# Optional: Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=2gis2traccar.log

# Optional: Reconnection settings
RECONNECT_DELAY=30
MAX_RECONNECT_ATTEMPTS=10

# Optional: Webhook Configuration
# Send data to n8n webhook endpoint
WEBHOOK_URL=webhook_url_here
WEBHOOK_TOKEN=your_bearer_token_here
WEBHOOK_TABLE_NAME=2gis_locations